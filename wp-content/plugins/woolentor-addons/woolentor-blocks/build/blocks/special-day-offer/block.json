      "style": {
        "selector": "{{WOOLENTOR_WRAPPER}} .banner-content { margin: {{contentAreaMargin}}; }"
      }
    },
    "contentAreaBGColor": {
      "type": "string",
      "style": {
        "selector": "{{WOOLENTOR_WRAPPER}} .banner-content{ background-color: {{contentAreaBGColor}}; }"
